{
  "info": {
    "name": "Slice 9 — Payments + Webhooks",
    "_postman_id": "b3f1a2c0-slice9-payments-0001",
    "description": "Razorpay order creation, payment verification, and webhook handling for the MERN backend (Slice 9). Uses collection variables so the whole flow — create order → verify → simulate webhook → check premium — can be run top to bottom against a local server.\n\nSetup:\n1. Set `baseUrl` (default http://localhost:5000).\n2. Run 'Register' or 'Login' first to populate `accessToken`.\n3. Run 'Create Order' — this stores `orderId` automatically.\n4. 'Verify Payment' auto-computes a valid signature using `razorpayKeySecret` (a TEST value you set in the collection variables — never your real secret in a shared collection).\n5. 'Simulate Webhook' auto-computes the X-Razorpay-Signature header using `razorpayWebhookSecret`.\n\nNote: these auto-signature scripts are for local testing only, where you have the test key/webhook secrets. In real usage, the signature is generated by Razorpay (checkout.js on the frontend, or Razorpay's servers for webhooks) — never by your own backend or Postman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "amount", "value": "499" },
    { "key": "currency", "value": "INR" },
    { "key": "razorpayKeySecret", "value": "REPLACE_WITH_TEST_RAZORPAY_KEY_SECRET" },
    { "key": "razorpayWebhookSecret", "value": "REPLACE_WITH_TEST_RAZORPAY_WEBHOOK_SECRET" },
    { "key": "fakePaymentId", "value": "pay_TEST12345" }
  ],
  "item": [
    {
      "name": "1. Register (helper)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Payer\",\n  \"email\": \"payer@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('accessToken', body.accessToken);",
              "  console.log('accessToken stored');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Login (helper, if already registered)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"payer@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('accessToken', body.accessToken);",
              "  console.log('accessToken stored');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Create Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": {{amount}},\n  \"currency\": \"{{currency}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/payments/create-order", "host": ["{{baseUrl}}"], "path": ["api", "payments", "create-order"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.code === 201);",
              "if (pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('orderId', body.orderId);",
              "  console.log('orderId stored:', body.orderId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3b. Create Order — invalid amount (expect 400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"amount\": -50\n}" },
        "url": { "raw": "{{baseUrl}}/api/payments/create-order", "host": ["{{baseUrl}}"], "path": ["api", "payments", "create-order"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "exec": ["pm.test('Status is 400', () => pm.response.code === 400);"] }
        }
      ]
    },
    {
      "name": "4. Verify Payment (auto-signed, TEST ONLY)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"razorpay_order_id\": \"{{orderId}}\",\n  \"razorpay_payment_id\": \"{{fakePaymentId}}\",\n  \"razorpay_signature\": \"{{computedPaymentSignature}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/payments/verify", "host": ["{{baseUrl}}"], "path": ["api", "payments", "verify"] }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Recreates the order_id|payment_id HMAC-SHA256 Razorpay's checkout.js",
              "// computes after a real payment. Only possible here because this is",
              "// a TEST key secret you control — never do this with a live secret",
              "// from anywhere other than your own backend.",
              "const orderId = pm.collectionVariables.get('orderId');",
              "const paymentId = pm.collectionVariables.get('fakePaymentId');",
              "const secret = pm.collectionVariables.get('razorpayKeySecret');",
              "const sig = CryptoJS.HmacSHA256(`${orderId}|${paymentId}`, secret).toString(CryptoJS.enc.Hex);",
              "pm.collectionVariables.set('computedPaymentSignature', sig);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.code === 200);",
              "pm.test('Payment status is success', () => pm.response.json().payment.status === 'success');"
            ]
          }
        }
      ]
    },
    {
      "name": "4b. Verify Payment — tampered signature (expect 400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"razorpay_order_id\": \"{{orderId}}\",\n  \"razorpay_payment_id\": \"{{fakePaymentId}}\",\n  \"razorpay_signature\": \"deliberately-wrong-signature\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/payments/verify", "host": ["{{baseUrl}}"], "path": ["api", "payments", "verify"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "exec": ["pm.test('Status is 400', () => pm.response.code === 400);"] }
        }
      ]
    },
    {
      "name": "5. Get My Profile (check isPremium)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/user/me", "host": ["{{baseUrl}}"], "path": ["api", "user", "me"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.code === 200);",
              "pm.test('User is premium', () => pm.response.json().user.isPremium === true);"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Simulate Webhook — payment.captured (auto-signed, TEST ONLY)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Razorpay-Signature", "value": "{{computedWebhookSignature}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"{{fakePaymentId}}\",\n        \"order_id\": \"{{orderId}}\",\n        \"amount\": {{amount}}00,\n        \"currency\": \"{{currency}}\",\n        \"status\": \"captured\"\n      }\n    }\n  }\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/payments/webhook", "host": ["{{baseUrl}}"], "path": ["api", "payments", "webhook"] }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// IMPORTANT: in real usage this signature is computed by Razorpay's",
              "// servers over the exact raw bytes they send. This script reconstructs",
              "// the body string the same way Postman will send it, purely so you can",
              "// test the endpoint locally with your own TEST webhook secret.",
              "const orderId = pm.collectionVariables.get('orderId');",
              "const paymentId = pm.collectionVariables.get('fakePaymentId');",
              "const amount = pm.collectionVariables.get('amount');",
              "const currency = pm.collectionVariables.get('currency');",
              "const secret = pm.collectionVariables.get('razorpayWebhookSecret');",
              "const body = JSON.stringify({",
              "  event: 'payment.captured',",
              "  payload: { payment: { entity: { id: paymentId, order_id: orderId, amount: Number(amount) * 100, currency, status: 'captured' } } }",
              "});",
              "const sig = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
              "pm.collectionVariables.set('computedWebhookSignature', sig);",
              "pm.request.body.raw = body;"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.code === 200);"
            ]
          }
        }
      ]
    },
    {
      "name": "6b. Simulate Webhook — replay same event (idempotency check)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Razorpay-Signature", "value": "{{computedWebhookSignature}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"{{fakePaymentId}}\",\n        \"order_id\": \"{{orderId}}\",\n        \"amount\": {{amount}}00,\n        \"currency\": \"{{currency}}\",\n        \"status\": \"captured\"\n      }\n    }\n  }\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/payments/webhook", "host": ["{{baseUrl}}"], "path": ["api", "payments", "webhook"] }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Re-send the exact same signature computed in step 6 to simulate",
              "// Razorpay retrying delivery of the same event.",
              "const orderId = pm.collectionVariables.get('orderId');",
              "const paymentId = pm.collectionVariables.get('fakePaymentId');",
              "const amount = pm.collectionVariables.get('amount');",
              "const currency = pm.collectionVariables.get('currency');",
              "const secret = pm.collectionVariables.get('razorpayWebhookSecret');",
              "const body = JSON.stringify({",
              "  event: 'payment.captured',",
              "  payload: { payment: { entity: { id: paymentId, order_id: orderId, amount: Number(amount) * 100, currency, status: 'captured' } } }",
              "});",
              "const sig = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
              "pm.collectionVariables.set('computedWebhookSignature', sig);",
              "pm.request.body.raw = body;"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.code === 200);",
              "pm.test('Marked as already processed', () => pm.response.json().message === 'Already processed');"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Simulate Webhook — tampered signature (expect 400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Razorpay-Signature", "value": "deliberately-wrong-signature" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"{{fakePaymentId}}\",\n        \"order_id\": \"{{orderId}}\"\n      }\n    }\n  }\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/payments/webhook", "host": ["{{baseUrl}}"], "path": ["api", "payments", "webhook"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "exec": ["pm.test('Status is 400', () => pm.response.code === 400);"] }
        }
      ]
    }
  ]
}
