# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# When running via `docker compose up`, this is overridden automatically to
# mongodb://mongo:27017/auth_db (see docker-compose.yml) — the value below is
# only used when running the app directly on your host machine.
MONGO_URI=mongodb://localhost:27017/auth_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Keep JWT_SECRET long and random (32+ chars) — especially in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token cookie TTL in milliseconds (7 days = 604800000)
REFRESH_TOKEN_COOKIE_MS=604800000

# ─── Redis ────────────────────────────────────────────────────────────────────
# When running via `docker compose up`, this is overridden automatically to
# host=redis (see docker-compose.yml) — the values below are only used when
# running the app directly on your host machine.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password  # uncomment if Redis requires auth

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of trusted origins (no trailing slashes)
# Production example: CLIENT_ORIGIN=https://your-frontend-app.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Secret configured on Razorpay Dashboard › Settings › Webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# AES-256-GCM key for encrypting stored GitHub tokens (32+ chars)
GITHUB_TOKEN_ENC_KEY=your_32plus_char_random_encryption_key

# ─── Seed script safety guard ─────────────────────────────────────────────────
# The seed script (npm run seed) refuses to run when NODE_ENV=production
# unless this is explicitly set to "true". Leave unset/false in real prod envs.
# ALLOW_PROD_SEED=true
